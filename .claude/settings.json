{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/cloudfront-pre-push.sh",
            "if": "Bash(git push*)",
            "timeout": 60,
            "statusMessage": "Validating CloudFront function on AWS..."
          }
        ]
      }
    ]
  }
}